# Environment Variables Manifest
# Real values are stored in Cloudflare Workers:
#   Dashboard → Workers & Pages → geo-aeo-compass
#     → Settings → Variables and Secrets

# OpenAI (v1 tracks ChatGPT only)
OPENAI_API_KEY=sk-proj-xxxxx

# Database (Supabase)
# VITE_ prefix = exposed to client (safe — designed for this)
# No prefix = server-only secret
VITE_SUPABASE_URL=https://xxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxx
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxx

# Future versions:
# v1.1: ANTHROPIC_API_KEY (Claude tracking)
# v1.2: PERPLEXITY_API_KEY (Perplexity tracking)
# v1.3: GEMINI_API_KEY (Gemini tracking)
# v1.4: DATAFORSEO_LOGIN + DATAFORSEO_PASSWORD (Google SERP)
# v1.5: APIFY_TOKEN (site crawling)
