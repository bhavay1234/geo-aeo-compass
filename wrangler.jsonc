{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "geo-aeo-compass",
  "compatibility_date": "2025-09-24",
  "compatibility_flags": ["nodejs_compat"],
  "main": "src/server.ts",
  "observability": { "enabled": true },
  "assets": {
    // Force /api/* to the Worker before the assets layer sees the request.
    // Without this, Cloudflare's static-assets edge can shadow worker
    // dispatch (SPA fallback, cached HTML, edge defaults), and /api/audit/start
    // ends up rendered as the React 404 page instead of hitting handleApiRoute.
    "run_worker_first": ["/api/*"]
  },
  "vars": {
    // Public URL — safe to commit. Source-controlled so deploys don't strip it
    // (dashboard plaintext vars have been getting wiped on redeploy).
    // Secrets (OPENAI_API_KEY, SUPABASE_SERVICE_ROLE_KEY, VITE_SUPABASE_ANON_KEY)
    // stay in the dashboard — DO NOT add them here.
    "VITE_SUPABASE_URL": "https://saxyymcncoxkkiajatkz.supabase.co"
  },
  "queues": {
    // Producer: POST /api/audit/start enqueues one message per query.
    // Consumer: batch size 1 — each query (and the citations stage) gets its
    // OWN invocation with a fresh subrequest budget, so per-query OpenAI fan-out
    // can never stack across queries and blow the 1000-subrequest cap.
    "producers": [
      { "queue": "audit-jobs", "binding": "AUDIT_QUEUE" }
    ],
    "consumers": [
      {
        "queue": "audit-jobs",
        "max_batch_size": 1,
        "max_batch_timeout": 2,
        "max_retries": 2,
        "max_concurrency": 10
      }
    ]
  }
}


